{
  "title": "Jenkins - DevSecOps Pipeline",
  "uid": "jenkins-devsecops",
  "tags": ["jenkins", "devsecops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jenkins Jobs",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jenkins_job_count_value" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Build Queue Size",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jenkins_queue_size_value" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 10 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Executors In Use / Total",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jenkins_executor_in_use_value", "legendFormat": "in use" },
        { "refId": "B", "expr": "jenkins_executor_count_value", "legendFormat": "total" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Nodes Online",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jenkins_node_online_value" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last Build Result (1 = success)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "default_jenkins_builds_last_build_result", "legendFormat": "{{jenkins_job}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Build Duration (ms) by Job",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "default_jenkins_builds_last_build_duration_milliseconds", "legendFormat": "{{jenkins_job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Usage (ratio)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "vm_memory_heap_usage_value", "legendFormat": "heap usage" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Builds: Success vs Failed (total)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "default_jenkins_builds_success_build_count", "legendFormat": "success {{jenkins_job}}" },
        { "refId": "B", "expr": "default_jenkins_builds_failed_build_count", "legendFormat": "failed {{jenkins_job}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Requests Active (Jenkins web UI)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "http_activeRequests_value", "legendFormat": "active requests" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] }
    }
  ]
}
