{
  "title": "Jenkins Metrics",
  "uid": "jenkins-metrics",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Executors In Use",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_executor_in_use_value",
          "legendFormat": "In Use"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Executors",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_executor_count_value",
          "legendFormat": "Total"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Jobs Count",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_job_count_value",
          "legendFormat": "Jobs"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Nodes Online",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_node_online_value",
          "legendFormat": "Online"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Build Duration (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_builds_last_build_duration_milliseconds",
          "legendFormat": "{{jenkins_job}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Build Result (1=success, 0=fail)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jenkins_builds_last_build_result",
          "legendFormat": "{{jenkins_job}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "vm_memory_heap_used",
          "legendFormat": "Heap Used"
        },
        {
          "datasource": "Prometheus",
          "expr": "vm_memory_heap_committed",
          "legendFormat": "Heap Committed"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
